<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="6dp">

    <!-- STATUS -->
    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="สถานะ: ไม่ได้เชื่อมต่อ"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:paddingBottom="4dp"/>

    <!-- VOLT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:gravity="center"
        android:orientation="vertical">

        <com.tnmower.tnmower.ui.GaugeView
            android:id="@+id/gaugeVolt"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/txtVolt"
            android:text="แรงดัน = 0.00 V"
            android:textColor="#00FF00"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- TEMP -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/layoutTempL"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <com.tnmower.tnmower.ui.GaugeView
                android:id="@+id/gaugeTempL"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/txtTempL"
                android:text="ซ้าย = 0 °C"
                android:textColor="#FFA500"
                android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutTempR"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <com.tnmower.tnmower.ui.GaugeView
                android:id="@+id/gaugeTempR"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/txtTempR"
                android:text="ขวา = 0 °C"
                android:textColor="#FFA500"
                android:textSize="10sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- CURRENT + MOTOR (เพิ่มพื้นที่) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="4"
        android:orientation="horizontal">

        <!-- LEFT -->
        <LinearLayout
            android:id="@+id/layoutLeft"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp">

            <com.tnmower.tnmower.ui.GaugeView
                android:id="@+id/gaugeCurrentL"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:text="กระแสซ้าย"
                android:textColor="#00FFFF"
                android:textSize="10sp"/>

            <!-- 🔴 MOTOR LEFT -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtM1"
                    android:text="M1 = 0.00 A"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"/>

                <TextView
                    android:id="@+id/txtM2"
                    android:text="M2 = 0.00 A"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- RIGHT -->
        <LinearLayout
            android:id="@+id/layoutRight"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp">

            <com.tnmower.tnmower.ui.GaugeView
                android:id="@+id/gaugeCurrentR"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:text="กระแสขวา"
                android:textColor="#00FFFF"
                android:textSize="10sp"/>

            <!-- 🔴 MOTOR RIGHT -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtM3"
                    android:text="M3 = 0.00 A"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"/>

                <TextView
                    android:id="@+id/txtM4"
                    android:text="M4 = 0.00 A"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- CONNECT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnConnect"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="เชื่อมต่อ"
            android:textSize="11sp"
            android:background="#4CAF50"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnDisconnect"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="ตัด"
            android:textSize="11sp"
            android:background="#FF9800"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- STOP -->
    <Button
        android:id="@+id/btnStop"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="หยุดฉุกเฉิน"
        android:textSize="12sp"
        android:background="@android:color/holo_red_dark"
        android:textColor="#FFFFFF"/>

</LinearLayout>