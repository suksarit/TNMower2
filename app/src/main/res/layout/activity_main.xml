<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- ========================= -->
    <!-- STATUS -->
    <!-- ========================= -->
    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="DISCONNECTED"
        android:textColor="#00E676"
        android:textSize="20sp"
        android:textStyle="bold"
        android:padding="10dp"
        android:background="#1E1E1E"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ========================= -->
    <!-- 🔴 แรงดัน -->
    <!-- ========================= -->
    <TextView
        android:id="@+id/labelVolt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="แรงดัน"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/txtStatus"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="16dp"/>

    <TextView
        android:id="@+id/txtVolt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0.0 V"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/labelVolt"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="16dp"/>

    <!-- ========================= -->
    <!-- 🔴 อุณหภูมิ -->
    <!-- ========================= -->
    <TextView
        android:id="@+id/labelTemp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="อุณหภูมิ (ซ้าย - ขวา)"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/txtVolt"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="16dp"/>

    <TextView
        android:id="@+id/txtTempL"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="L: 0.0 °C"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        app:layout_constraintTop_toBottomOf="@id/labelTemp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/txtTempR"
        app:layout_constraintWidth_percent="0.5"
        android:layout_marginStart="16dp"/>

    <TextView
        android:id="@+id/txtTempR"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="R: 0.0 °C"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        app:layout_constraintTop_toBottomOf="@id/labelTemp"
        app:layout_constraintStart_toEndOf="@id/txtTempL"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.5"/>

    <!-- ========================= -->
    <!-- 🔴 กระแส -->
    <!-- ========================= -->
    <TextView
        android:id="@+id/labelCurrent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="กระแส (M1 - M4)"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/txtTempL"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="16dp"/>

    <!-- ROW 1 -->
    <TextView
        android:id="@+id/txtM1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="M1: 0.0 A"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@id/labelCurrent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/txtM2"
        app:layout_constraintWidth_percent="0.5"
        android:layout_marginStart="16dp"/>

    <TextView
        android:id="@+id/txtM2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="M2: 0.0 A"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@id/labelCurrent"
        app:layout_constraintStart_toEndOf="@id/txtM1"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ROW 2 -->
    <TextView
        android:id="@+id/txtM3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="M3: 0.0 A"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@id/txtM1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/txtM4"
        app:layout_constraintWidth_percent="0.5"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"/>

    <TextView
        android:id="@+id/txtM4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="M4: 0.0 A"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@id/txtM2"
        app:layout_constraintStart_toEndOf="@id/txtM3"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"/>

    <!-- ========================= -->
    <!-- BUTTON -->
    <!-- ========================= -->

    <Button
        android:id="@+id/btnConnect"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:text="CONNECT"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2E7D32"
        app:layout_constraintBottom_toTopOf="@id/btnStop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnDisconnect"
        android:layout_margin="8dp"/>

    <Button
        android:id="@+id/btnDisconnect"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:text="DISCONNECT"
        android:textColor="#FFFFFF"
        android:backgroundTint="#C62828"
        app:layout_constraintBottom_toTopOf="@id/btnStop"
        app:layout_constraintStart_toEndOf="@id/btnConnect"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="8dp"/>

    <Button
        android:id="@+id/btnStop"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="EMERGENCY STOP"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF6F00"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="10dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>